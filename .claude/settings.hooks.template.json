{
  "_comment": "PORTABLE hook template \u2014 version-controlled source of truth. Rendered per-machine by scripts/machine_parity.py --fix. {{PY}} = OS interpreter, $CLAUDE_PROJECT_DIR = repo root. DO NOT hand-edit paths.",
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "supabase",
    "n8n-mcp",
    "stripe",
    "sequential-thinking",
    "playwright",
    "late",
    "context7",
    "memory"
  ],
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{PY}} $CLAUDE_PROJECT_DIR/scripts/hooks/subagent_stop_validator.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{PY}} $CLAUDE_PROJECT_DIR/scripts/audit_mcp_secrets.py --quiet"
          },
          {
            "type": "command",
            "command": "{{PY}} $CLAUDE_PROJECT_DIR/scripts/hooks/session_start.py"
          },
          {
            "type": "command",
            "command": "{{PY}} $CLAUDE_PROJECT_DIR/scripts/ensure_cockpit.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{PY}} $CLAUDE_PROJECT_DIR/scripts/hooks/user_prompt_submit.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{PY}} $CLAUDE_PROJECT_DIR/scripts/hooks/pre_compact.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{{PY}} $CLAUDE_PROJECT_DIR/scripts/state/secret_guard.py"
          },
          {
            "type": "command",
            "command": "{{PY}} $CLAUDE_PROJECT_DIR/scripts/state/exec_guard.py"
          },
          {
            "type": "command",
            "command": "{{PY}} $CLAUDE_PROJECT_DIR/scripts/hooks/anti_pattern_hook.py"
          }
        ]
      },
      {
        "matcher": "PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "{{PY}} $CLAUDE_PROJECT_DIR/scripts/state/secret_guard.py"
          },
          {
            "type": "command",
            "command": "{{PY}} $CLAUDE_PROJECT_DIR/scripts/state/exec_guard.py"
          }
        ]
      },
      {
        "matcher": "Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "{{PY}} $CLAUDE_PROJECT_DIR/scripts/state/secret_guard.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "{{PY}} $CLAUDE_PROJECT_DIR/scripts/state/secret_guard.py"
          },
          {
            "type": "command",
            "command": "{{PY}} $CLAUDE_PROJECT_DIR/scripts/state/state_guard.py"
          },
          {
            "type": "command",
            "command": "{{PY}} $CLAUDE_PROJECT_DIR/scripts/hooks/subprocess_guard.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "{{PY}} $CLAUDE_PROJECT_DIR/scripts/retriever_postedit.py"
          }
        ]
      }
    ]
  }
}
