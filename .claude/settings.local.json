{
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Read(//c/Users/User/SunBiz-Agent/**)",
      "Read(//c/Users/User/Business-Empire-Agent/**)",
      "WebSearch",
      "Bash(find /c/Users/User/SunBiz-Agent -type f -name *.md -o -name *.json -o -name *.txt -o -name *.yaml -o -name *.yml -o -name .*rules)"
    ],
    "additionalDirectories": [
      "c:\\Users\\User\\Business-Empire-Agent"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Users/User/Business-Empire-Agent/scripts/audit_mcp_secrets.py --quiet"
          },
          {
            "type": "command",
            "command": "python C:/Users/User/Business-Empire-Agent/scripts/hooks/session_start.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Users/User/Business-Empire-Agent/scripts/hooks/user_prompt_submit.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Users/User/Business-Empire-Agent/scripts/hooks/pre_compact.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Users/User/Business-Empire-Agent/scripts/state/secret_guard.py"
          },
          {
            "type": "command",
            "command": "python C:/Users/User/Business-Empire-Agent/scripts/state/exec_guard.py"
          },
          {
            "type": "command",
            "command": "python C:/Users/User/Business-Empire-Agent/scripts/hooks/anti_pattern_hook.py"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Users/User/Business-Empire-Agent/scripts/state/secret_guard.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Users/User/Business-Empire-Agent/scripts/state/secret_guard.py"
          },
          {
            "type": "command",
            "command": "python C:/Users/User/Business-Empire-Agent/scripts/state/state_guard.py"
          },
          {
            "type": "command",
            "command": "python C:/Users/User/Business-Empire-Agent/scripts/hooks/subprocess_guard.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python C:/Users/User/Business-Empire-Agent/scripts/retriever_postedit.py"
          }
        ]
      }
    ]
  },
  "enabledMcpjsonServers": [
    "sequential-thinking",
    "playwright",
    "context7",
    "memory",
    "knowledge-graph"
  ]
}
